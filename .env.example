# ──────────────────────────────────────────────────────────────────
#  FYRP — Environment Variables
#  Copy this file to .env and fill in your values.
#  The .env file is gitignored; NEVER commit real keys.
# ──────────────────────────────────────────────────────────────────

# ── LLM Provider (change this one line to switch providers) ────────
LLM_PROVIDER=groq                        # options: groq | openai
LLM_MODEL=llama3-70b-8192               # optional — uses provider default if unset

# ── Groq (free tier, fast) — https://console.groq.com ──────────────
GROQ_API_KEY=your-groq-api-key-here     # starts with gsk_

# ── OpenAI (paid) — https://platform.openai.com/api-keys ───────────
# OPENAI_API_KEY=your-openai-api-key-here   # starts with sk-

